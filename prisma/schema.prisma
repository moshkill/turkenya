// Turkenya Tours & Safaris — database schema
// PostgreSQL on Linode. Run `npx prisma migrate deploy` after setting DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User — admin/agent accounts. Admins manage everything + accounts; agents
// log in and work leads. Passwords are scrypt-hashed (salt:hash).
model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("agent") // admin | agent
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  leads        Lead[]   @relation("AssignedLeads")

  @@map("users")
}

// Lead — every contact form submission, AI chat handoff, or quote request
model Lead {
  id           Int      @id @default(autoincrement())
  name         String
  email        String?
  phone        String
  service      String?
  travelDates  String?  @map("travel_dates")
  message      String?  @db.Text
  source       String   @default("contact") // contact | chat | quote
  status       String   @default("new")     // new | contacted | converted | closed | lost
  assignedToId Int?     @map("assigned_to_id")
  assignedTo   User?    @relation("AssignedLeads", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages     LeadMessage[]
  createdAt    DateTime @default(now())      @map("created_at")
  updatedAt    DateTime @updatedAt           @map("updated_at")

  @@index([status])
  @@index([createdAt])
  @@index([assignedToId])
  @@map("leads")
}

// LeadMessage — two-way thread between an agent and the customer on a booking.
// Customer authenticates by reference + phone (no account); agent via session.
// An agent message can carry a price offer (price + terms fixed|negotiable).
model LeadMessage {
  id        Int      @id @default(autoincrement())
  leadId    Int      @map("lead_id")
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sender    String   // 'agent' | 'customer'
  body      String   @db.Text
  price     String?  // optional offer price (display string, e.g. "KES 45,000")
  terms     String?  // 'fixed' | 'negotiable' — set on agent price offers
  lastPrice String?  @map("last_price") // best/floor price for a negotiable offer
  authorName String? @map("author_name") // agent first name, for display
  createdAt DateTime @default(now()) @map("created_at")

  @@index([leadId, createdAt])
  @@map("lead_messages")
}

// BlogPost — AI-generated articles (auto-blog). Layered on top of the
// hand-written static articles; newest appear first on /blog.
model BlogPost {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  title     String
  category  String
  excerpt   String   @db.Text
  content   String   @db.Text
  image     String
  readTime  String   @default("5 min") @map("read_time")
  published Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([published, createdAt])
  @@map("blog_posts")
}

// Offer — admin-created packages (safari, international…) shown on the site
// as postcard cards. Only active ones are public; sort orders the deck.
model Offer {
  id         Int      @id @default(autoincrement())
  title      String
  category   String   @default("Safari") // Safari | International
  image      String
  price      String   // display string, e.g. "From KES 45,000" / "POA"
  duration   String?  // e.g. "3D / 2N"
  tagline    String?
  highlights String?  @db.Text // newline-separated
  featured   Boolean  @default(false)
  active     Boolean  @default(true)
  sort       Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([active, category, sort])
  @@map("offers")
}

// Testimonial — visitor-submitted reviews. Moderated: approved=false until an
// admin approves; featured ones surface on the homepage.
model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  location  String?  // e.g. "London, UK" / "Nairobi"
  service   String?  // which service they used
  rating    Int      @default(5) // 1–5 stars
  message   String   @db.Text
  approved  Boolean  @default(false)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([approved, featured])
  @@index([createdAt])
  @@map("testimonials")
}

// ChatMessage — optional log of AI concierge conversations for quality/training
model ChatMessage {
  id        Int      @id @default(autoincrement())
  sessionId String   @map("session_id")
  role      String   // user | assistant
  text      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@map("chat_messages")
}
