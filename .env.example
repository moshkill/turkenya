# Turkenya Tours & Safaris — environment variables
# Copy this file to `.env` on the server and fill in real values.
# NEVER commit the real .env (it is git-ignored).

# --- Database (PostgreSQL on Linode) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://turkenya:CHANGE_ME@localhost:5432/turkenya?schema=public"

# --- Admin dashboard ---
# Shared secret the /admin page sends as the x-admin-token header.
# Use a long random string. Generate: openssl rand -hex 32
ADMIN_TOKEN="CHANGE_ME_long_random_string"

# --- Claude AI concierge (Anthropic) ---
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-CHANGE_ME"

# --- Lead notifications (optional) ---
# Webhook URL that relays new leads to WhatsApp/sales team.
# Leave blank until the WhatsApp pipeline is set up — leads still save.
WHATSAPP_NOTIFY_URL=""
